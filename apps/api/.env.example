# Runtime
LLM_PROVIDER=openai
OLLAMA_HOST=http://127.0.0.1:11434

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_SIGNAL_MODEL=gpt-4o-mini
OPENAI_PLAYBOOK_MODEL=gpt-4o-mini

# Nemotron via local Ollama on the host
NEMOTRON_MODEL=nemotron-3-super

# FRED API (미국 거시지표)
# https://fred.stlouisfed.org
FRED_API_KEY=your-fred-api-key

# ECOS API (한국은행 경제통계시스템)
# https://ecos.bok.or.kr
ECOS_API_KEY=your-ecos-api-key

# DART API (전자공시 Open API)
# https://opendart.fss.or.kr
DART_API_KEY=

# 한국투자증권 Open API (선택)
# 실전: https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_CANO=
KIS_ACCOUNT_ACNT_PRDT_CD=

# 텔레그램 봇 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REPORT_WEB_URL=http://localhost:8081

# 이메일 발송 (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_RECIPIENT=

# 발송 방식 (telegram / email / both / none)
DELIVERY_METHOD=none

# 리포트/로그 경로
REPORT_OUTPUT_DIR=/reports
LOGS_DIR=/logs
