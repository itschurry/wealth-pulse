# FRED API (미국 거시지표)
# https://fred.stlouisfed.org
FRED_API_KEY=your-fred-api-key

# ECOS API (한국은행 경제통계시스템)
# https://ecos.bok.or.kr
ECOS_API_KEY=your-ecos-api-key

# DART API (전자공시 Open API)
# https://opendart.fss.or.kr
DART_API_KEY=

# 한국투자증권 Open API (선택)
# 실전: https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
# 계좌번호 앞 8자리
KIS_ACCOUNT_CANO=12345678
# 계좌 상품코드 뒤 2자리 (일반 위탁: 01)
KIS_ACCOUNT_ACNT_PRDT_CD=01

# ────────────────────────────────────────────────────────
# 주의: 이 프로젝트는 실거래 API를 사용하지만 내부 가상계좌로 처리함
# 실거래 서버 (현재 사용 중)
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS 공식 모의투자 계좌 사용 시 아래로 교체
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
# ────────────────────────────────────────────────────────

# 실행 모드: paper (내부 가상계좌) | live (실거래 주문 실제 집행)
# 절대 live로 바꾸기 전에 체크리스트 확인할 것 (docs/live-trading-checklist.md)
EXECUTION_MODE=paper

# 리포트/로그 경로
# 로컬 실행에서는 비워두면 기본값으로
# storage/reports, storage/logs 를 사용합니다.
# Docker 실행에서는 docker-compose 가 /reports, /logs 로 override 합니다.
