# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# FRED API (미국 거시지표)
# https://fred.stlouisfed.org
FRED_API_KEY=your-fred-api-key

# ECOS API (한국은행 경제통계시스템)
# https://ecos.bok.or.kr
ECOS_API_KEY=your-ecos-api-key

# 텔레그램 봇 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 이메일 발송 (선택)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_RECIPIENT=

# 발송 방식 (telegram / email / both / none)
DELIVERY_METHOD=none

# 리포트 저장 경로 (기본값: ./report)
REPORT_OUTPUT_DIR=./report
